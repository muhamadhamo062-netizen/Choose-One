{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install",
  "functions": {
    "app/api/webhooks/paddle/route.ts": {
      "maxDuration": 60
    },
    "app/api/internal/queue/process/route.ts": {
      "maxDuration": 60
    },
    "app/api/internal/recurring/scan/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/internal/queue/process?limit=25",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/internal/recurring/scan",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-metrics",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/monthly-audit",
      "schedule": "0 8 1,15 * *"
    },
    {
      "path": "/api/internal/removal/process?mode=execute&limit=25",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/internal/removal/process?mode=verify&limit=25",
      "schedule": "0 3 * * *"
    }
  ]
}
