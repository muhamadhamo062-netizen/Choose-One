{
  "name": "privacyeraser-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/ensure-prisma.cjs && npx tsx -r tsconfig-paths/register scripts/validate-env-database.ts && node scripts/pwa-generate-icons.cjs",
    "predev": "node scripts/ensure-prisma.cjs && node scripts/pwa-generate-icons.cjs",
    "dev": "node scripts/run-with-env-local.cjs next dev",
    "build": "node scripts/run-with-env-local.cjs npx prisma generate && next build",
    "vercel-build": "node scripts/pwa-generate-icons.cjs && npx prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:product": "eslint app components --ext .js,.jsx,.ts,.tsx --max-warnings 0 --ignore-pattern \"app/api/**\"",
    "db:generate": "node scripts/run-with-env-local.cjs npx prisma generate",
    "db:generate:local": "node scripts/run-with-env-local.cjs npx prisma generate",
    "db:push:local": "node scripts/run-with-env-local.cjs npx prisma db push",
    "db:push:local:ipv4": "node scripts/prisma-with-local-env.cjs db push",
    "db:check": "npx tsx -r tsconfig-paths/register scripts/validate-env-database.ts",
    "db:ping": "node scripts/db-ping.cjs",
    "auth:reset-password": "node scripts/reset-user-password.cjs",
    "db:diagnose": "node scripts/diagnose-supabase-connection.cjs",
    "db:ensure": "node scripts/ensure-db.cjs",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-postgres-windows.ps1",
    "db:ready": "node scripts/run-with-env-local.cjs npx prisma generate && node scripts/ensure-db.cjs && node scripts/run-with-env-local.cjs npx prisma db push && node scripts/db-ping.cjs",
    "e2e:verify": "node scripts/run-with-env-local.cjs node scripts/runtime-e2e-verify.cjs",
    "e2e:verify:http": "node scripts/run-with-env-local.cjs node scripts/runtime-e2e-verify.cjs --http",
    "dev:local": "npm run dev",
    "dev:stable": "npm run db:force && npm run dev",
    "dev:direct": "next dev",
    "test:webhook:local": "node scripts/run-with-env-local.cjs node scripts/paddle-webhook-e2e.cjs",
    "db:push": "node scripts/run-with-env-local.cjs npx prisma db push",
    "db:fix": "node scripts/run-with-env-local.cjs npx prisma generate && node scripts/run-with-env-local.cjs npx prisma db push --accept-data-loss",
    "db:force": "node scripts/db-force-sync.cjs",
    "db:force-sync": "node scripts/db-force-sync.cjs",
    "db:migrate": "node scripts/run-with-env-local.cjs npx prisma migrate dev",
    "worker:scan": "npx --no-install tsx -r tsconfig-paths/register workers/scan-worker.ts",
    "worker:recurring": "npx --no-install tsx -r tsconfig-paths/register workers/recurring-scan.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@prisma/client": "^5.22.0",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^2.4.3",
    "framer-motion": "^11.3.19",
    "jose": "^5.10.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.453.0",
    "next": "14.2.15",
    "prisma": "^5.22.0",
    "puppeteer": "^24.43.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.8.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "eslint-plugin-privacy-eraser": "file:./eslint-plugin-privacy-eraser",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
