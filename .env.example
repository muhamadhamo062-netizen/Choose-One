# Core app:
# NEXT_PUBLIC_SITE_URL="https://your-domain.com"
# SESSION_SECRET="replace-with-32-or-more-random-chars-please!!"
# ADMIN_EMAILS="muhamadhamo062@gmail.com"
#
# Database (pooler-only strategy currently used in this repo):
# DATABASE_URL="postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# DIRECT_URL="postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
#
# Leak intelligence:
# LEAK_PROVIDER="leakcheck"
# LEAKCHECK_API_KEY=""
# LEAK_CACHE_TTL_SECONDS="86400"
#
# Email (Resend):
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="onboarding@resend.dev"
# CONTACT_INBOX_TO="muhamadhamo062@gmail.com"
#
# Payments (Lemon Squeezy):
# LEMON_SQUEEZY_WEBHOOK_SECRET=""
# NEXT_PUBLIC_LEMON_SQUEEZY_CHECKOUT_URL=""
# NEXT_PUBLIC_LEMON_SQUEEZY_STORE_SLUG=""
# NEXT_PUBLIC_LEMON_SQUEEZY_VARIANT_ID=""
#
# Optional but recommended:
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
# CRON_SECRET=""
