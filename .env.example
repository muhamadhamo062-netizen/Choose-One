# === Supabase + Prisma (مطلوب — لا localhost / Docker) ===
# 1) Supabase: Project not paused. Settings → Database.
# 2) Copy full URIs: (a) Connection pooling → Transaction, port 6543  (b) Direct connection, db.*.supabase.co:5432
# 3) Never guess pooler host — copy aws-0-<region>.pooler... from the UI only.
# 4) If the copied string omits Prisma params, append:  &pgbouncer=true&connection_limit=1&sslmode=require&schema=public
# 5) Local runbook:  npm install  →  npx prisma generate  →  npm run db:check  →  npm run db:ping  →  npx prisma db push  →  npm run dev
# 6) Vercel: set DATABASE_URL and DIRECT_URL (both).
#
# prisma/schema: url = DATABASE_URL, directUrl = DIRECT_URL
#
DIRECT_URL="postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?sslmode=require&schema=public"
DATABASE_URL="postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require&schema=public"
# Optional: Supabase Session pooler (:5432 on *.pooler.supabase.com). If unset, signup/login derive it from DATABASE_URL on Vercel.
# AUTH_DATABASE_URL="postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require&schema=public"

# Optional: max in-process funnel `events` ingest queue (see lib/events/ingest-queue.ts). Use a durable external queue in heavy serverless if needed.
# EVENTS_INGEST_MAX_QUEUE=100000

# Same origin as SUPABASE_URL — enables “Open Database settings” link on signup errors (client)
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_REF.supabase.co"
# Optional: Supabase publishable key (client-only; does not replace DATABASE_URL for Prisma)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Supabase JS / REST (optional for this app’s Prisma-only paths; still set for future use). Keys are long JWTs from Settings → API (not short test strings)
# SUPABASE_URL="https://YOUR_REF.supabase.co"
# SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...."
# SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...."

# Required: HS256 for `pe_session` — same in every deploy, 32+ characters.
SESSION_SECRET="replace-with-32-or-more-random-chars-please!!"

# `next start` over http:// (NODE_ENV=production): set exactly 1 or `pe_session` cannot be stored
# SESSION_COOKIE_INSECURE=1

# Step 5: skip middleware (NextResponse.next only) to isolate cookie/session issues
# PE_MIDDLEWARE_PASSTHROUGH=1

# Extra session logs (SESSION VALID, etc.)
# AUTH_DEBUG=1

# Optional: allow signup with ?from=payment to grant lifetime without Paddle webhook (use false in production)
# PE_ALLOW_CLIENT_LIFETIME="false"

# Unverified client-triggered entitlements (unsafe for production; use until Paddle webhooks are implemented)
# PE_ALLOW_UNVERIFIED_COMPLETE_PURCHASE="false"
# PE_ALLOW_UNVERIFIED_ACTIVATE_LIFETIME="false"

# Contact form → Resend (real delivery). If unset, /api/contact returns 503; UI is honest.
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="onboarding@resend.dev"
# CONTACT_INBOX_TO="muhamadhamo062@gmail.com"

# Lemon Squeezy (production payment): webhook signing secret; route POST /api/webhooks/lemon-squeezy
# LEMON_SQUEEZY_WEBHOOK_SECRET=""

# Client checkout (pick one approach):
# NEXT_PUBLIC_LEMON_SQUEEZY_CHECKOUT_URL="https://YOUR_STORE.lemonsqueezy.com/checkout/buy/VARIANT_ID"
# — or —
# NEXT_PUBLIC_LEMON_SQUEEZY_STORE_SLUG="YOUR_STORE"
# NEXT_PUBLIC_LEMON_SQUEEZY_VARIANT_ID="123456"

# Vercel Cron / internal queue: required in production to process scan_jobs
# CRON_SECRET=""  # Bearer token for /api/cron/* (incl. bi-weekly /api/cron/monthly-audit)
# RESEND_API_KEY="" # Bi-weekly audit emails (sendBiWeeklyPrivacyAuditEmail)
# RESEND_FROM_EMAIL=""

# Upstash Redis rate limiting for /api/scan* (3 scans/IP/day)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Discovery connector (optional; without it, scans persist with empty broker lists)
# PE_DISCOVERY_CONNECTOR_URL=""
# PE_DISCOVERY_CONNECTOR_TOKEN=""

# Deep scan provider (real breach intelligence)
# LEAK_PROVIDER="leakcheck" # or "dehashed"
# LEAKCHECK_API_URL="https://leakcheck.io/api/public"
# LEAKCHECK_API_KEY=""
# DEHASHED_API_URL="https://api.dehashed.com/search"
# DEHASHED_USERNAME=""
# DEHASHED_API_KEY=""
# INTELX_API_KEY=""
# INTELX_BASE_URL="https://2.intelx.io"
# INTELX_MAX_RESULTS="40"
# INTELX_RESULT_LIMIT="30"
# LEAK_CACHE_TTL_SECONDS="86400"
# SEARCHAPI_API_KEY="" # optional: public records / people-search enrichment

# DigitalOcean Spaces (reports storage only)
# Used for Privacy Audit PDFs / Case Reports uploads (NOT for breach search).
# SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"
# SPACES_REGION="us-east-1"
# SPACES_ACCESS_KEY_ID=""
# SPACES_SECRET_ACCESS_KEY=""
# SPACES_REPORTS_BUCKET=""
# SPACES_REPORTS_PREFIX="reports/"
# SPACES_PUBLIC_BASE_URL="https://YOUR_BUCKET.nyc3.digitaloceanspaces.com"

# Real broker opt-out execution (production removal engine)
# WHITEPAGES_OPTOUT_API_URL=""
# SPOKEO_OPTOUT_API_URL=""
# WHITEPAGES_OPTOUT_EMAIL=""
# SPOKEO_OPTOUT_EMAIL=""
# MYLIFE_OPTOUT_EMAIL="privacy@mylife.com"
# RADARIS_OPTOUT_EMAIL=""
# INTELIUS_OPTOUT_EMAIL=""
# BROKER_OPTOUT_FALLBACK_EMAIL=""

# Affiliate / admin controls
# ADMIN_EMAILS="muhamadhamo062@gmail.com"

# -----------------------------
# Vercel Production Checklist
